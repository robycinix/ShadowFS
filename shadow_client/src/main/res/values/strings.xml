    <string name="onboarding_notifications_title">Notifications (1/3)</string>
    <string name="onboarding_notifications_message">ShadowFS uses notifications to tell you about:\n\n• Uploads and downloads in progress\n• Raspberry Pi unreachable\n• Files restored successfully\n\nTap Allow in the dialog that appears.</string>
    <string name="button_allow">Allow</string>
    <string name="button_skip">Skip</string>
    <string name="onboarding_storage_title">File access (2/3)</string>
    <string name="onboarding_storage_message">ShadowFS needs access to ALL files to ghost and restore photos, videos, and documents.\n\nIn the settings that open:\n  1. Find ShadowFS in the list\n  2. Enable \"Allow access to manage all files\"\n  3. Come back here</string>
    <string name="button_open_settings">Open Settings</string>
    <string name="onboarding_battery_title">Battery (3/3)</string>
    <string name="onboarding_battery_message">To ghost files in the background without interruptions, ShadowFS must be excluded from battery optimization, otherwise Android may suspend it after a few minutes.\n\nIn settings:\n  1. Find ShadowFS\n  2. Choose \"Do not optimize\" or \"No restrictions\"\n  3. Come back here</string>
