    <string name="notif_contested_title">ShadowFS — Conflitto con app cloud</string>
    <string name="notif_contested_text">\"%1$s\" viene continuamente ripristinato da un\'app di backup cloud (Google Photos? Amazon Photos?). ShadowFS non lo ghosterà più per evitare un loop. Per liberare spazio: disattiva il backup cloud per quella cartella.</string>
    <string name="notif_upload_title">ShadowFS — Upload in corso</string>
    <string name="notif_unreachable_title">ShadowFS — Raspberry irraggiungibile</string>
    <string name="notif_unreachable_text">Impossibile ghostare i file. Controlla che il Raspberry sia acceso e connesso.</string>
    <string name="notif_service_title">ShadowFS Attivo</string>
    <string name="notif_service_text">Memoria ottimizzata in background</string>
    <string name="notif_hydrating_text">Scaricando \"%1$s\" dal Raspberry Pi…</string>
    <string name="notif_hydration_done_text">\"%1$s\" ripristinato e disponibile.</string>
    <string name="notif_hydration_budget_title">ShadowFS — Possibile loop con app cloud</string>
    <string name="notif_hydration_budget_text">Troppe idratazioni automatiche nell\'ultima ora: probabilmente un\'app di backup cloud (Google/Amazon Photos) sta scandendo i file ghost in loop. Idratazione in pausa per un po\'. Suggerimento: disattiva il backup cloud per le cartelle gestite da ShadowFS.</string>
