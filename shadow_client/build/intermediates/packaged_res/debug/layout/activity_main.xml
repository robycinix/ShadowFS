<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="👻 ShadowFS"
            android:textColor="#E0E0FF"
            android:textSize="30sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingTop="16dp"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="File Ghosting Intelligente"
            android:textColor="#8080A0"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingBottom="20dp" />

        <!-- Status principale -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚙️ Configura l'IP del Raspberry Pi per iniziare"
            android:textColor="#A0B0FF"
            android:textSize="14sp"
            android:gravity="center"
            android:padding="12dp"
            android:background="#1A1A2E"
            android:layout_marginBottom="12dp" />

        <!-- Spazio libero -->
        <TextView
            android:id="@+id/tv_space"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💾 Caricamento..."
            android:textColor="#80C0A0"
            android:textSize="13sp"
            android:gravity="center"
            android:paddingBottom="16dp" />

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#2A2A3A" android:layout_marginBottom="16dp"/>

        <!-- Sezione: Configurazione Server -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🌐 RASPBERRY PI (SERVER)"
            android:textColor="#8080FF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:paddingBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <EditText
                android:id="@+id/et_server_ip"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="3"
                android:hint="IP server (es. 100.80.33.12)"
                android:inputType="text"
                android:textColor="#E0E0FF"
                android:textColorHint="#505065"
                android:background="#1A1A2E"
                android:padding="12dp"
                android:layout_marginEnd="8dp" />

            <EditText
                android:id="@+id/et_server_port"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Porta"
                android:text="4243"
                android:inputType="number"
                android:textColor="#E0E0FF"
                android:textColorHint="#505065"
                android:background="#1A1A2E"
                android:padding="12dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btn_save_config"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="💾 Salva"
                android:backgroundTint="#2A3A6A"
                android:textColor="#A0B8FF"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btn_discover"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔍 Cerca in Wi-Fi"
                android:backgroundTint="#1A3A3A"
                android:textColor="#60D0D0"/>
        </LinearLayout>

        <Button
            android:id="@+id/btn_test_connection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔌 Testa Connessione mTLS"
            android:backgroundTint="#1A3A2A"
            android:textColor="#80D0A0"
            android:layout_marginBottom="16dp" />

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#2A2A3A" android:layout_marginBottom="16dp"/>

        <!-- Sezione: Certificati -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔒 CERTIFICATI mTLS"
            android:textColor="#8080FF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:paddingBottom="8dp"/>

        <TextView
            android:id="@+id/tv_cert_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="❌ Certificati mancanti"
            android:textColor="#FF8080"
            android:textSize="13sp"
            android:paddingBottom="4dp"/>

        <TextView
            android:id="@+id/tv_cert_path"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#606070"
            android:textSize="11sp"
            android:layout_marginBottom="16dp"/>

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#2A2A3A" android:layout_marginBottom="16dp"/>

        <!-- Sezione: Permessi -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📁 PERMESSI"
            android:textColor="#8080FF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:paddingBottom="8dp"/>

        <Button
            android:id="@+id/btn_permission"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠️ Richiedi Permesso Gestione File"
            android:backgroundTint="#3A2A1A"
            android:textColor="#FFB060"
            android:layout_marginBottom="16dp" />

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#2A2A3A" android:layout_marginBottom="16dp"/>

        <!-- Sezione: Controllo Daemon -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚙️ CONTROLLO DAEMON"
            android:textColor="#8080FF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:paddingBottom="8dp"/>

        <Button
            android:id="@+id/btn_start_service"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="▶ Avvia Shadow Daemon"
            android:backgroundTint="#1A3A1A"
            android:textColor="#80E080"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_force_offload"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚡ Libera Spazio Adesso (Forza Ghosting)"
            android:backgroundTint="#3A1A1A"
            android:textColor="#FF8080"
            android:enabled="false"
            android:layout_marginBottom="24dp" />

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#2A2A3A" android:layout_marginBottom="16dp"/>

        <!-- Pulsante lista file ghostati -->
        <Button
            android:id="@+id/btn_ghost_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="👻 Vedi File Ghostati"
            android:backgroundTint="#1A1A3A"
            android:textColor="#8080FF"
            android:layout_marginBottom="16dp"/>

        <!-- Sommario spazio recuperato -->
        <TextView
            android:id="@+id/tv_ghost_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#80D0A0"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <!-- Footer info -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ℹ️  Il daemon monitora la memoria ogni ora. Quando lo spazio scende sotto il 15%, i file inattivi da più di 3 giorni vengono automaticamente 'ghostati' sul Raspberry Pi."
            android:textColor="#505060"
            android:textSize="11sp"
            android:gravity="center"
            android:paddingBottom="20dp"/>

    </LinearLayout>
</ScrollView>
